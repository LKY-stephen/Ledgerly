{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@ledgerly/schemas": ["packages/schemas/src/index.ts"],
      "@ledgerly/storage": ["packages/storage/src/index.ts"],
      "@ledgerly/ui": ["packages/ui/src/index.ts"]
    }
  }
}
